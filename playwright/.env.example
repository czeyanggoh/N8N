# Copy to .env and fill in. NEVER commit .env.
# DBS IDEAL credentials
DBS_USERNAME=
DBS_PASSWORD=
# Display name or ID of the organisation to select after login. Match the text shown on the org-picker screen exactly.
DBS_ORG_NAME=

# Optional: URL override (default below points at the live SG corporate banking site)
DBS_IDEAL_URL=https://ideal.dbs.com.sg/

# Internal HTTP API shared secret — n8n sends this in the X-API-Key header
PLAYWRIGHT_API_KEY=change-me-to-a-long-random-string

# How long (ms) to wait for the user to approve the digital token push on their phone
MFA_TIMEOUT_MS=180000

# Headless behaviour: stays "false" (headed under Xvfb) for stealth
HEADLESS=false

LOG_LEVEL=info
